---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { client } from '../config/client';

const pageTitle = `Over Ons — ${client.brand.name} ${client.brand.tagline}`;
const pageDesc = `Leer meer over ${client.brand.name}, uw betrouwbare loodgieter in ${client.brand.location}.`;
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <style>
    .page-hero {
      background: var(--navy);
      color: #fff;
      padding: 8rem 2rem 5rem;
      text-align: center;
    }
    .page-hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      letter-spacing: -.04em;
      margin: 0 0 1rem;
    }
    .page-hero p {
      color: rgba(255,255,255,.7);
      font-size: 1.1rem;
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.65;
    }

    .about-section {
      padding: 5rem 2rem;
      background: var(--bg);
    }
    .about-inner {
      max-width: 900px;
      margin: 0 auto;
    }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    @media (max-width: 700px) {
      .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    }
    .about-text h2 {
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 900;
      color: var(--navy);
      letter-spacing: -.03em;
      margin: 0 0 1.25rem;
    }
    .about-text p {
      color: var(--ink);
      opacity: .8;
      line-height: 1.75;
      font-size: 1rem;
      margin: 0 0 1.25rem;
    }
    .about-text p:last-child { margin: 0; }

    .values-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .value-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }
    .value-icon {
      width: 40px; height: 40px; flex-shrink: 0;
      background: rgba(24,71,237,.1);
      border-radius: .625rem;
      display: flex; align-items: center; justify-content: center;
      color: var(--blue);
    }
    .value-item h3 { font-size: .95rem; font-weight: 800; color: var(--navy); margin: 0 0 .25rem; }
    .value-item p { font-size: .875rem; color: var(--ink); opacity: .7; margin: 0; line-height: 1.5; }

    .stats-strip {
      background: var(--navy);
      padding: 4rem 2rem;
    }
    .stats-grid {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 2rem;
      text-align: center;
    }
    .stat-value {
      font-size: clamp(2rem, 4vw, 2.75rem);
      font-weight: 900;
      color: #fff;
      letter-spacing: -.04em;
    }
    .stat-label {
      font-size: .85rem;
      color: rgba(255,255,255,.6);
      margin-top: .25rem;
    }

    .certifications {
      padding: 5rem 2rem;
      background: var(--surface);
    }
    .cert-inner {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }
    .cert-inner h2 {
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 900;
      color: var(--navy);
      margin: 0 0 .75rem;
    }
    .cert-inner > p {
      color: var(--ink);
      opacity: .7;
      margin: 0 0 3rem;
    }
    .cert-badges {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
    .cert-badge {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: .75rem;
      padding: .875rem 1.5rem;
      font-size: .9rem;
      font-weight: 700;
      color: var(--navy);
      display: flex;
      align-items: center;
      gap: .5rem;
    }
    .cert-dot { width: 8px; height: 8px; background: #22c55e; border-radius: 50%; }

    .cta-strip {
      background: var(--blue);
      color: #fff;
      padding: 4rem 2rem;
      text-align: center;
    }
    .cta-strip h2 { font-size: clamp(1.5rem, 4vw, 2.5rem); font-weight: 900; margin: 0 0 1rem; }
    .cta-strip p { color: rgba(255,255,255,.8); margin: 0 0 2rem; font-size: 1.05rem; }
    .cta-btn {
      display: inline-flex; align-items: center; gap: .5rem;
      background: #fff; color: var(--blue);
      padding: 1rem 2.25rem; border-radius: .75rem;
      font-size: 1.05rem; font-weight: 700; text-decoration: none;
      box-shadow: 0 8px 24px rgba(0,0,0,.15);
      transition: opacity .2s, transform .15s;
    }
    .cta-btn:hover { opacity: .9; transform: translateY(-2px); }
  </style>

  <div class="page-hero">
    <h1>Over {client.brand.name}</h1>
    <p>Al meer dan 15 jaar uw vertrouwde loodgieter in {client.brand.location} en omgeving.</p>
  </div>

  <section class="about-section">
    <div class="about-inner">
      <div class="about-grid">
        <div class="about-text">
          <h2>Wie zijn wij?</h2>
          <p>
            {client.brand.name} {client.brand.tagline} is een erkend loodgietersbedrijf gevestigd in {client.brand.location}.
            We zijn gespecialiseerd in alle soorten loodgieterswerkzaamheden: van kleine herstellingen
            tot complete installaties.
          </p>
          <p>
            Ons team van gecertificeerde loodgieters staat 7 dagen op 7, 24 uur op 24 voor u klaar.
            We hechten veel belang aan transparantie, kwaliteit en snelheid — zonder verborgen kosten.
          </p>
          <p>
            Met meer dan 4.800 tevreden klanten en 15 jaar ervaring weten we wat u nodig heeft:
            een loodgieter die snel, eerlijk en vakkundig werkt.
          </p>
        </div>

        <div class="values-list">
          <div class="value-item">
            <div class="value-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <div>
              <h3>Snelle interventie</h3>
              <p>Gemiddeld binnen 45 minuten ter plaatse in {client.brand.location}.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h3>Geen verborgen kosten</h3>
              <p>U ontvangt altijd een duidelijke prijsindicatie vóór we beginnen.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
            </div>
            <div>
              <h3>Erkend & gecertificeerd</h3>
              <p>Volledig vergund en verzekerd, met garantie op alle werkzaamheden.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <h3>24/7 bereikbaar</h3>
              <p>Ook in het weekend en op feestdagen voor noodgevallen.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="stats-strip">
    <div class="stats-grid">
      {client.stats.map(stat => (
        <div>
          <div class="stat-value">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="certifications">
    <div class="cert-inner">
      <h2>Erkenningen & Certificaten</h2>
      <p>We werken volledig vergund, verzekerd en gecertificeerd.</p>
      <div class="cert-badges">
        <div class="cert-badge"><span class="cert-dot"></span> Erkend aannemer</div>
        <div class="cert-badge"><span class="cert-dot"></span> BA-verzekeraar</div>
        <div class="cert-badge"><span class="cert-dot"></span> Gasinstallateur vergund</div>
        <div class="cert-badge"><span class="cert-dot"></span> Sanitair gecertificeerd</div>
        <div class="cert-badge"><span class="cert-dot"></span> Cv-installateur</div>
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <h2>Kennismaking of offerte?</h2>
    <p>Bel ons vrijblijvend — we beantwoorden uw vragen en plannen een afspraak.</p>
    <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="cta-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      Bel {client.brand.phone}
    </a>
  </section>
</BaseLayout>
