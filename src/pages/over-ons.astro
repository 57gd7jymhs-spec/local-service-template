---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { client } from '../config/client';

const a = client.about;
const pageTitle = `Over Ons — ${client.brand.name} ${client.brand.tagline}`;
const pageDesc = a.heading;

const iconPaths: Record<string, string> = {
  bolt:     '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  shield:   '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  badge:    '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>',
  clock:    '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  users:    '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>',
  star:     '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
};

const hasTeam = a.team.length > 0;
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <style>
    .page-hero {
      background: var(--navy);
      color: #fff;
      padding: 8rem 2rem 5rem;
      text-align: center;
    }
    .page-hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      letter-spacing: -.04em;
      margin: 0 0 1rem;
    }
    .page-hero p {
      color: rgba(255,255,255,.7);
      font-size: 1.1rem;
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.65;
    }

    .about-section {
      padding: 5rem 2rem;
      background: var(--bg);
    }
    .about-inner {
      max-width: 900px;
      margin: 0 auto;
    }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    @media (max-width: 700px) {
      .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    }
    .about-text h2 {
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 900;
      color: var(--navy);
      letter-spacing: -.03em;
      margin: 0 0 1.25rem;
    }
    .about-text p {
      color: var(--ink);
      opacity: .8;
      line-height: 1.75;
      font-size: 1rem;
      margin: 0 0 1.25rem;
    }
    .about-text p:last-child { margin: 0; }

    .values-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .value-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }
    .value-icon {
      width: 40px; height: 40px; flex-shrink: 0;
      background: rgba(24,71,237,.1);
      border-radius: .625rem;
      display: flex; align-items: center; justify-content: center;
      color: var(--blue);
    }
    .value-icon svg { width: 18px; height: 18px; }
    .value-item h3 { font-size: .95rem; font-weight: 800; color: var(--navy); margin: 0 0 .25rem; }
    .value-item p { font-size: .875rem; color: var(--ink); opacity: .7; margin: 0; line-height: 1.5; }

    .stats-strip {
      background: var(--navy);
      padding: 4rem 2rem;
    }
    .stats-grid {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 2rem;
      text-align: center;
    }
    .stat-value {
      font-size: clamp(2rem, 4vw, 2.75rem);
      font-weight: 900;
      color: #fff;
      letter-spacing: -.04em;
    }
    .stat-label {
      font-size: .85rem;
      color: rgba(255,255,255,.6);
      margin-top: .25rem;
    }

    .certifications {
      padding: 5rem 2rem;
      background: var(--surface);
    }
    .cert-inner {
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }
    .cert-inner h2 {
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 900;
      color: var(--navy);
      margin: 0 0 .75rem;
    }
    .cert-inner > p {
      color: var(--ink);
      opacity: .7;
      margin: 0 0 3rem;
    }
    .cert-badges {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
    .cert-badge {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: .75rem;
      padding: .875rem 1.5rem;
      font-size: .9rem;
      font-weight: 700;
      color: var(--navy);
      display: flex;
      align-items: center;
      gap: .5rem;
    }
    .cert-dot { width: 8px; height: 8px; background: #22c55e; border-radius: 50%; }

    .team-section {
      padding: 5rem 2rem;
      background: var(--bg);
    }
    .team-inner {
      max-width: 960px;
      margin: 0 auto;
    }
    .team-header { text-align: center; margin-bottom: 3rem; }
    .team-header h2 {
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 900;
      color: var(--navy);
      margin: 0 0 .5rem;
    }
    .team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 2rem;
    }
    .team-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 1.25rem;
      overflow: hidden;
      text-align: center;
    }
    .team-card img {
      width: 100%; aspect-ratio: 3/4; object-fit: cover;
    }
    .team-card-body { padding: 1.5rem; }
    .team-card-body h3 { font-size: 1.05rem; font-weight: 800; color: var(--navy); margin: 0 0 .25rem; }
    .team-card-body .role { font-size: .875rem; color: var(--blue); font-weight: 600; margin: 0 0 .75rem; }
    .team-card-body p { font-size: .875rem; color: var(--muted); line-height: 1.6; margin: 0 0 1rem; }
    .team-badges { display: flex; flex-wrap: wrap; gap: .375rem; justify-content: center; }
    .team-badge { font-size: .7rem; font-weight: 700; background: #EFF4FF; color: var(--blue); padding: .25rem .625rem; border-radius: .375rem; }

    .cta-strip {
      background: var(--blue);
      color: #fff;
      padding: 4rem 2rem;
      text-align: center;
    }
    .cta-strip h2 { font-size: clamp(1.5rem, 4vw, 2.5rem); font-weight: 900; margin: 0 0 1rem; }
    .cta-strip p { color: rgba(255,255,255,.8); margin: 0 0 2rem; font-size: 1.05rem; }
    .cta-btn {
      display: inline-flex; align-items: center; gap: .5rem;
      background: #fff; color: var(--blue);
      padding: 1rem 2.25rem; border-radius: .75rem;
      font-size: 1.05rem; font-weight: 700; text-decoration: none;
      box-shadow: 0 8px 24px rgba(0,0,0,.15);
      transition: opacity .2s, transform .15s;
    }
    .cta-btn:hover { opacity: .9; transform: translateY(-2px); }
  </style>

  <div class="page-hero">
    <h1>Over {client.brand.name}</h1>
    <p>{a.heading}</p>
  </div>

  <section class="about-section">
    <div class="about-inner">
      <div class="about-grid">
        <div class="about-text">
          <h2>{a.eyebrow}</h2>
          {a.body.map(paragraph => (
            <p>{paragraph}</p>
          ))}
        </div>

        <div class="values-list">
          {a.values.map(v => (
            <div class="value-item">
              <div class="value-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round"
                     set:html={iconPaths[v.icon] ?? iconPaths.bolt} />
              </div>
              <div>
                <h3>{v.title}</h3>
                <p>{v.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="stats-strip">
    <div class="stats-grid">
      {client.stats.map(stat => (
        <div>
          <div class="stat-value">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="certifications">
    <div class="cert-inner">
      <h2>Erkenningen &amp; Certificaten</h2>
      <p>We werken volledig vergund, verzekerd en gecertificeerd.</p>
      <div class="cert-badges">
        {a.certifications.map(cert => (
          <div class="cert-badge"><span class="cert-dot"></span> {cert}</div>
        ))}
      </div>
    </div>
  </section>

  {hasTeam && (
    <section class="team-section">
      <div class="team-inner">
        <div class="team-header">
          <h2>Ons team</h2>
        </div>
        <div class="team-grid">
          {a.team.map(member => (
            <div class="team-card">
              <img src={member.image} alt={member.name} loading="lazy" />
              <div class="team-card-body">
                <h3>{member.name}</h3>
                <div class="role">{member.role}</div>
                <p>{member.bio}</p>
                {member.badges.length > 0 && (
                  <div class="team-badges">
                    {member.badges.map(b => (
                      <span class="team-badge">{b}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="cta-strip">
    <h2>Kennismaking of offerte?</h2>
    <p>Bel ons vrijblijvend — we beantwoorden uw vragen en plannen een afspraak.</p>
    <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="cta-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      Bel {client.brand.phone}
    </a>
  </section>
</BaseLayout>
