---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { client } from '../config/client';

const pageTitle = `Diensten — ${client.brand.name} ${client.brand.tagline}`;
const pageDesc = `Overzicht van alle diensten van ${client.brand.name}: ${client.services.map(s => s.title).join(', ')}.`;

const icons: Record<string, string> = {
  droplet: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>`,
  drain:   `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="9"/><line x1="12" y1="15" x2="12" y2="22"/><line x1="2" y1="12" x2="9" y2="12"/><line x1="15" y1="12" x2="22" y2="12"/></svg>`,
  flame:   `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 01-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 2.5z"/></svg>`,
  wrench:  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
  pipe:    `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  shield:  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
};
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <style>
    .page-hero {
      background: var(--navy);
      color: #fff;
      padding: 8rem 2rem 5rem;
      text-align: center;
    }
    .page-hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      letter-spacing: -.04em;
      margin: 0 0 1rem;
    }
    .page-hero p {
      color: rgba(255,255,255,.7);
      font-size: 1.1rem;
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.65;
    }

    .services-section {
      padding: 5rem 2rem;
      background: var(--bg);
    }
    .services-grid {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }
    .service-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: box-shadow .2s, transform .2s;
    }
    .service-card:hover {
      box-shadow: 0 12px 40px rgba(13,30,92,.1);
      transform: translateY(-4px);
    }
    .icon-wrap {
      width: 56px; height: 56px;
      background: rgba(24,71,237,.1);
      border-radius: .75rem;
      display: flex; align-items: center; justify-content: center;
      color: var(--blue);
    }
    .service-card h2 { font-size: 1.25rem; font-weight: 800; color: var(--navy); margin: 0; }
    .service-price {
      font-size: .9rem; font-weight: 700;
      color: var(--blue);
      background: rgba(24,71,237,.08);
      border-radius: 2rem;
      padding: .25rem .75rem;
      width: fit-content;
    }
    .service-card p { color: var(--ink); opacity: .75; font-size: .95rem; line-height: 1.65; margin: 0; flex: 1; }
    .service-cta {
      display: inline-flex; align-items: center; gap: .5rem;
      color: var(--blue); font-weight: 700; font-size: .9rem;
      text-decoration: none;
      margin-top: auto;
    }
    .service-cta:hover { text-decoration: underline; }

    .cta-strip {
      background: var(--navy);
      color: #fff;
      padding: 4rem 2rem;
      text-align: center;
    }
    .cta-strip h2 { font-size: clamp(1.5rem, 4vw, 2.5rem); font-weight: 900; margin: 0 0 1rem; }
    .cta-strip p { color: rgba(255,255,255,.7); margin: 0 0 2rem; font-size: 1.05rem; }
    .cta-btn {
      display: inline-flex; align-items: center; gap: .5rem;
      background: var(--blue); color: #fff;
      padding: 1rem 2.25rem; border-radius: .75rem;
      font-size: 1.05rem; font-weight: 700; text-decoration: none;
      box-shadow: 0 8px 24px rgba(24,71,237,.4);
      transition: background .2s, transform .15s;
    }
    .cta-btn:hover { background: #0f35c4; transform: translateY(-2px); }
  </style>

  <div class="page-hero">
    <h1>Onze Diensten</h1>
    <p>Professionele loodgietersdiensten met vaste prijsindicaties en geen verborgen kosten.</p>
  </div>

  <section class="services-section">
    <div class="services-grid">
      {client.services.map(service => (
        <article class="service-card">
          <div class="icon-wrap" set:html={icons[service.icon] ?? icons.wrench} />
          <h2>{service.title}</h2>
          <span class="service-price">{service.price}</span>
          <p>{service.description}</p>
          <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="service-cta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            Bel voor meer info
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="cta-strip">
    <h2>Spoed of vraag? Bel direct.</h2>
    <p>Gemiddeld binnen 45 minuten ter plaatse in de regio {client.brand.location}.</p>
    <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="cta-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      {client.hero.ctaLabel} {client.brand.phone}
    </a>
  </section>
</BaseLayout>
