---
import { client } from '../../config/client';

const sa = client.serviceAreas;
---

<style>
.areas-section { padding: 4rem 1.5rem; background: var(--navy); }
.areas-inner {
  max-width: 72rem; margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 3rem;
  align-items: center;
}
@media (max-width: 768px) {
  .areas-inner { grid-template-columns: 1fr; gap: 2rem; }
}
.areas-left .eyebrow { color: rgba(255,255,255,.5); }
.areas-left h2 {
  font-size: clamp(1.75rem, 3.5vw, 2.5rem) !important;
  font-weight: 900 !important;
  color: #fff !important;
  letter-spacing: -.03em !important;
  line-height: 1.15 !important;
  margin: 0 0 .875rem !important;
}
.areas-left p {
  font-size: .9375rem;
  color: rgba(255,255,255,.55);
  line-height: 1.65;
  margin: 0 0 1.5rem;
}
.call-cta {
  display: inline-flex; align-items: center; gap: .625rem;
  background: var(--blue); color: #fff;
  padding: .75rem 1.5rem;
  border-radius: .75rem;
  font-weight: 700; font-size: .9375rem;
  text-decoration: none;
  box-shadow: 0 4px 16px rgba(24,71,237,.4);
  transition: background .2s, transform .15s;
}
.call-cta:hover { background: #0f35c4; transform: translateY(-2px); }
.call-cta svg { width: 1rem; height: 1rem; }

.areas-tags {
  display: flex; flex-wrap: wrap; gap: .625rem;
}
.area-tag {
  display: inline-flex; align-items: center; gap: .375rem;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.12);
  color: rgba(255,255,255,.82);
  border-radius: .5rem;
  padding: .5rem .875rem;
  font-size: .875rem; font-weight: 500;
  transition: background .2s, border-color .2s;
}
.area-tag:hover {
  background: rgba(255,255,255,.12);
  border-color: rgba(255,255,255,.22);
}
.area-tag svg { width: .8125rem; height: .8125rem; opacity: .5; }
</style>

<section class="areas-section" id="werkgebied">
  <div class="areas-inner">
    <div class="areas-left" data-reveal>
      <span class="eyebrow">{sa.eyebrow}</span>
      <h2>{sa.heading}</h2>
      <p>{sa.subtext}</p>
      <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="call-cta">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        Bel ons direct
      </a>
    </div>

    <div class="areas-tags" data-reveal data-delay="1">
      {sa.areas.map(area => (
        <span class="area-tag">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          {area}
        </span>
      ))}
    </div>
  </div>
</section>
