---
import { client } from '../../../config/client';
---

<style>
.services-grid { display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;margin-bottom:2.5rem; }
.service-card {
  position:relative;overflow:hidden;background:#fff;border:1px solid var(--border);
  border-radius:1.25rem;padding:2rem;text-align:center;
  transition:box-shadow .3s var(--ease),background .2s;
  transform-style:preserve-3d;will-change:transform;
}
.service-card:hover { box-shadow:0 16px 48px rgba(24,71,237,.12);background:#FAFBFF; }
.service-card.featured { background:var(--navy);border-color:var(--navy); }
.service-card.featured h3,.service-card.featured p { color:#fff; }
.service-card.featured .service-tag { background:rgba(255,255,255,.12);color:rgba(255,255,255,.85); }
.service-card.featured .service-link { color:rgba(255,255,255,.9); }
.service-card.featured .service-link:hover { color:#fff; }
.service-card.card-blue { background:var(--blue);border-color:var(--blue); }
.service-card.card-blue h3,.service-card.card-blue p { color:#fff; }
.service-card.card-blue .service-tag { background:rgba(255,255,255,.15);color:rgba(255,255,255,.9); }
.service-card.card-blue .service-link { color:rgba(255,255,255,.9); }
.service-card.card-blue:hover { background:#1238C7; }
.service-card.card-light { background:#EFF4FF;border-color:#DBEAFE; }
.service-card.card-light:hover { background:#E0EBFF; }
.service-tag {
  display:inline-flex;align-items:center;justify-content:center;gap:.375rem;
  font-size:.75rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;
  color:var(--blue);background:#EFF4FF;border-radius:.5rem;
  padding:.25rem .625rem;margin-bottom:1.25rem;
}
.service-tag svg { width:.875rem;height:.875rem; }
.service-card h3 { font-size:1.25rem;font-weight:800;color:var(--navy);margin:0 0 .75rem;letter-spacing:-.02em; }
.service-card p { font-size:.9375rem;color:var(--muted);line-height:1.65;margin:0 0 1.5rem; }
.service-link {
  display:inline-flex;align-items:center;justify-content:center;gap:.5rem;
  font-size:.875rem;font-weight:600;color:var(--blue);text-decoration:none;transition:gap .2s;
}
.service-link:hover { gap:.75rem; }
.service-link svg { width:.875rem;height:.875rem; }
.services-cta { text-align:center;padding:1.5rem 0 0; }
.btn-primary {
  display:inline-flex;align-items:center;gap:.75rem;background:var(--blue);color:#fff;
  font-weight:700;font-size:1.125rem;padding:1rem 2rem;border-radius:.875rem;
  text-decoration:none;box-shadow:0 12px 32px rgba(24,71,237,.28);
  transition:background .2s,transform .2s,box-shadow .2s;
}
.btn-primary:hover { background:#1238C7;transform:translateY(-2px); }
@keyframes iconFloat   { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-3px)} }
@keyframes iconPulse   { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.7;transform:scale(1.15)} }
@keyframes iconFlicker { 0%,100%{opacity:1} 45%{opacity:.75} 50%{opacity:1} 55%{opacity:.6} 60%{opacity:1} }
.service-card:nth-child(1) .service-tag svg { animation:iconFlicker 2.8s ease-in-out infinite; }
.service-card:nth-child(2) .service-tag svg { animation:iconFloat 3s ease-in-out infinite; }
.service-card:nth-child(3) .service-tag svg { animation:iconPulse 2.4s ease-in-out infinite; }
.service-card:nth-child(4) .service-tag svg { animation:iconFloat 3.5s ease-in-out infinite .4s; }
@media(max-width:768px){ .services-grid{grid-template-columns:1fr} }
</style>

<section class="section" id="diensten">
  <div class="wrap">
    <div class="section-header" data-reveal>
      <span class="eyebrow">Wat wij oplossen</span>
      <h2>Elk loodgietersprobleem, dezelfde dag opgelost.</h2>
      <p>Van gesprongen pijpen om 2u 's nachts tot geplande badkamerinstallaties. Eén nummer, elke klus.</p>
    </div>
    <div class="services-grid">
      <div class="service-card featured" data-reveal data-delay="1">
        <div class="service-tag" style="background:rgba(255,255,255,.12);color:rgba(255,255,255,.85)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Prioriteit respons
        </div>
        <h3>Noodloodgieters</h3>
        <p>Gesprongen pijp, overstroomde vloer, geen warm water. Wij zijn ter plaatse binnen 45 minuten, dag en nacht. Geen meerprijs buiten kantooruren.</p>
        <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="service-link">
          Bel nu
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="service-card card-blue" data-reveal data-delay="2">
        <div class="service-tag">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
          Lek specialist
        </div>
        <h3>Lekdetectie &amp; Reparatie</h3>
        <p>Verborgen lekken kosten honderden euro's aan verspild water en structurele schade. Wij lokaliseren de bron precies en herstellen het in één beurt.</p>
        <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="service-link">
          Offerte aanvragen
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="service-card card-light" data-reveal data-delay="3">
        <div class="service-tag">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          Afvoer specialist
        </div>
        <h3>Afvoer Ontstopping</h3>
        <p>Trage afvoeren, terugstroom, slechte geuren — binnen het uur verholpen met professionele persapparatuur. Geen rommel, geen beschadiging.</p>
        <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="service-link">
          Vandaag boeken
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="service-card" data-reveal data-delay="4">
        <div class="service-tag">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          Verwarming
        </div>
        <h3>Ketel Reparatie &amp; Onderhoud</h3>
        <p>Geen verwarming, geen warm water — wij onderhouden alle merken en modellen. Jaarlijkse onderhoudsplannen met prioriteit beschikbaar.</p>
        <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="service-link">
          Ketel laten nakijken
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
    <div class="services-cta" data-reveal>
      <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="btn-primary">Bel voor elke klus</a>
      <span style="display:block;font-size:.875rem;color:var(--muted);margin-top:.75rem">Geen voorrijkosten · Prijs vóór aanvang</span>
    </div>
  </div>
</section>

<script>
document.querySelectorAll('.service-card').forEach(card => {
  const el = card as HTMLElement;
  el.addEventListener('mousemove', (e: MouseEvent) => {
    const r = el.getBoundingClientRect();
    const x = (e.clientX - r.left) / r.width - 0.5;
    const y = (e.clientY - r.top) / r.height - 0.5;
    el.style.transform = `perspective(700px) rotateX(${-y * 7}deg) rotateY(${x * 7}deg)`;
  });
  el.addEventListener('mouseleave', () => {
    el.style.transition = 'transform .5s var(--ease), box-shadow .3s var(--ease)';
    el.style.transform = '';
    setTimeout(() => { el.style.transition = ''; }, 500);
  });
  el.addEventListener('mouseenter', () => { el.style.transition = 'box-shadow .3s var(--ease)'; });
});
</script>
