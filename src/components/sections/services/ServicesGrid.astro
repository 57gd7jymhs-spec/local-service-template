---
import { client } from '../../../config/client';
---

<style>
  .services { padding: 6rem 2rem; background: var(--bg); }
  .section-header { text-align: center; max-width: 560px; margin: 0 auto 3.5rem; }
  .section-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: var(--blue); margin-bottom: .75rem; }
  .section-title { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 900; color: var(--ink); letter-spacing: -.03em; line-height: 1.1; margin: 0 0 1rem; }
  .section-sub { color: var(--muted); line-height: 1.6; font-size: .95rem; margin: 0; }
  .grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem; max-width: 1200px; margin: 0 auto;
  }
  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.75rem;
    transition: transform .2s, box-shadow .2s, border-color .2s;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(24,71,237,.1); border-color: rgba(24,71,237,.2); }
  .icon-wrap {
    width: 48px; height: 48px; background: rgba(24,71,237,.08);
    border-radius: .75rem; display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.1rem; color: var(--blue);
  }
  .card-title { font-size: 1.05rem; font-weight: 800; color: var(--ink); margin: 0 0 .5rem; }
  .card-desc { font-size: .875rem; color: var(--muted); line-height: 1.55; margin: 0 0 1.1rem; }
  .card-price { font-size: .8rem; font-weight: 700; color: var(--blue); background: rgba(24,71,237,.06); border-radius: .375rem; padding: .25rem .6rem; display: inline-block; }
</style>

<section class="services" id="diensten">
  <div class="section-header">
    <div class="section-label">Onze diensten</div>
    <h2 class="section-title">Wat kunnen we voor u doen?</h2>
    <p class="section-sub">Professionele service voor al uw sanitaire problemen — snel, transparant en met garantie.</p>
  </div>
  <div class="grid">
    {client.services.map(service => (
      <div class="card">
        <div class="icon-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
        <div class="card-title">{service.title}</div>
        <p class="card-desc">{service.description}</p>
        <span class="card-price">{service.price}</span>
      </div>
    ))}
  </div>
</section>
