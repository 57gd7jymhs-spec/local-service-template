---
import { client } from '../../../config/client';

const s = client.sections.services;
const phone = client.brand.phone.replace(/\s/g, '');

const iconPaths: Record<string, string> = {
  droplet:  '<path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/>',
  drain:    '<line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>',
  flame:    '<path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
  wrench:   '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>',
  scissors: '<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>',
  home:     '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  zap:      '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  tool:     '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>',
};
---

<style>
.list-section { padding:5rem 1.5rem; background:var(--bg); }
.services-list { display:flex;flex-direction:column;gap:1px;border-radius:1.25rem;overflow:hidden;border:1px solid var(--border); }
.service-row {
  display:grid;grid-template-columns:3rem 1fr auto;align-items:center;gap:1.5rem;
  background:#fff;padding:1.5rem 2rem;
  transition:background .2s;
}
.service-row:hover { background:#FAFBFF; }
.service-icon {
  width:3rem;height:3rem;border-radius:.875rem;background:#EFF4FF;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--blue);
}
.service-icon svg { width:1.25rem;height:1.25rem; }
.service-info { min-width:0; }
.service-info h3 { font-size:1rem;font-weight:800;color:var(--navy);margin:0 0 .25rem;letter-spacing:-.01em; }
.service-info p { font-size:.875rem;color:var(--muted);line-height:1.55;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
.service-meta { display:flex;flex-direction:column;align-items:flex-end;gap:.5rem;flex-shrink:0; }
.service-price-pill {
  font-size:.8125rem;font-weight:700;color:var(--blue);
  background:#EFF4FF;border-radius:.5rem;padding:.25rem .75rem;white-space:nowrap;
}
.service-cta-link {
  font-size:.8125rem;font-weight:600;color:var(--muted);text-decoration:none;
  display:flex;align-items:center;gap:.25rem;transition:color .2s;
}
.service-cta-link:hover { color:var(--blue); }
.service-cta-link svg { width:.875rem;height:.875rem; }
.services-cta { text-align:center;padding:2rem 0 0; }
.btn-primary {
  display:inline-flex;align-items:center;gap:.75rem;background:var(--blue);color:#fff;
  font-weight:700;font-size:1.125rem;padding:1rem 2rem;border-radius:.875rem;
  text-decoration:none;box-shadow:0 12px 32px rgba(24,71,237,.28);
  transition:background .2s,transform .2s;
}
.btn-primary:hover { background:#1238C7;transform:translateY(-2px); }
@media(max-width:600px){
  .service-row { grid-template-columns:2.5rem 1fr;padding:1.25rem 1.25rem; }
  .service-meta { display:none; }
}
</style>

<section class="list-section section" id="diensten">
  <div class="wrap">
    <div class="section-header" data-reveal>
      <span class="eyebrow">{s.eyebrow}</span>
      <h2>{s.heading}</h2>
      <p>{s.subtext}</p>
    </div>
    <div class="services-list">
      {client.services.map((svc, i) => (
        <div class="service-row" data-reveal data-delay={String(i + 1)}>
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 set:html={iconPaths[svc.icon] ?? iconPaths.wrench} />
          </div>
          <div class="service-info">
            <h3>{svc.title}</h3>
            <p>{svc.description}</p>
          </div>
          <div class="service-meta">
            <span class="service-price-pill">{svc.price}</span>
            <a href={`tel:${phone}`} class="service-cta-link">
              Boek nu
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
    <div class="services-cta" data-reveal>
      <a href={`tel:${phone}`} class="btn-primary">Bel voor meer info</a>
    </div>
  </div>
</section>
