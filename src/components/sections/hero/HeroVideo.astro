---
import { client } from '../../../config/client';
---

<style>
.hero {
  min-height:100vh; background:var(--navy);
  display:flex;flex-direction:column;justify-content:center;
  padding:7.5rem 1.5rem 4rem; position:relative;overflow:hidden;
}
.hero-video {
  position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;z-index:0;pointer-events:none;
}
.hero-video-overlay {
  position:absolute;inset:0;z-index:1;pointer-events:none;
  background:linear-gradient(135deg,rgba(13,30,92,.85) 0%,rgba(13,30,92,.65) 45%,rgba(0,0,0,.5) 100%);
}
.orb { position:absolute;border-radius:50%;filter:blur(56px);pointer-events:none; }
.orb-1 { top:-10rem;right:-10rem;width:32rem;height:32rem;background:rgba(24,71,237,.15);z-index:1; }
.orb-2 { bottom:-8rem;left:-8rem;width:26rem;height:26rem;background:rgba(56,189,248,.1);z-index:1; }
.grid-bg {
  position:absolute;inset:0;pointer-events:none;z-index:1;
  background-image:linear-gradient(rgba(255,255,255,1) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,1) 1px,transparent 1px);
  background-size:48px 48px;opacity:.04;
}
.hero-inner {
  position:relative;z-index:10;width:100%;max-width:72rem;margin:0 auto;
  display:flex;align-items:center;justify-content:space-between;gap:3rem;
}
/* Trust badge */
.trust-badge {
  display:inline-flex;align-items:center;gap:.5rem;
  background:#fff;border:1px solid var(--border);border-radius:9999px;
  padding:.375rem 1rem;margin-bottom:2rem;
  box-shadow:0 1px 4px rgba(0,0,0,.05);font-size:.875rem;font-weight:500;color:#334155;
  animation:fadeUp .6s .1s var(--ease) both;
}
.live-wrap { position:relative;width:.5rem;height:.5rem;flex-shrink:0; }
.live-core,.live-ring { position:absolute;inset:0;border-radius:50%;background:#10b981; }
.live-ring { opacity:.75;animation:ping 1.5s ease-in-out infinite; }

/* Headline */
h1.hero-h1 {
  font-size:clamp(3rem,7.5vw,5rem) !important;font-weight:900 !important;
  line-height:1.06 !important;letter-spacing:-.035em !important;
  color:#fff !important;margin:0 0 1rem !important;
  animation:fadeUp .6s .2s var(--ease) both;
}
.rotating-wrap { position:relative;display:inline-block;min-width:18rem; }
.rotating-word { display:block;color:var(--blue);animation:wordIn .42s var(--ease) both; }
@keyframes wordIn  { from{opacity:0;transform:translateY(14px);filter:blur(4px)}to{opacity:1;transform:none;filter:blur(0)} }
@keyframes wordOut { from{opacity:1;transform:none;filter:blur(0)}to{opacity:0;transform:translateY(-14px);filter:blur(4px)} }

/* Sub text */
.hero-sub {
  font-size:1.125rem;line-height:1.75;color:rgba(255,255,255,.72);
  max-width:36rem;margin:0 0 2.5rem;animation:fadeUp .6s .35s var(--ease) both;
}

/* CTA */
.cta-row { display:flex;flex-wrap:wrap;gap:.75rem;margin-bottom:3rem;animation:fadeUp .6s .45s var(--ease) both; }
.btn-primary {
  display:inline-flex;align-items:center;gap:.75rem;background:var(--blue);color:#fff;
  font-weight:700;font-size:1.125rem;padding:1rem 2rem;border-radius:.875rem;
  text-decoration:none;box-shadow:0 12px 32px rgba(24,71,237,.28);
  transition:background .2s,transform .2s,box-shadow .2s;
}
.btn-primary:hover { background:#1238C7;transform:translateY(-2px);box-shadow:0 16px 40px rgba(24,71,237,.38); }
.btn-primary svg { width:1.25rem;height:1.25rem; }
.btn-phone { font-size:.875rem;font-weight:400;opacity:.8; }

/* Trust pills */
.trust-row { display:flex;flex-wrap:wrap;gap:1.5rem 2rem;animation:fadeUp .6s .55s var(--ease) both; }
.trust-pill { display:flex;align-items:center;gap:.5rem;font-size:.875rem;font-weight:500;color:rgba(255,255,255,.75); }
.trust-pill svg { color:rgba(255,255,255,.9);width:1rem;height:1rem;flex-shrink:0; }

/* Info card */
.info-card {
  flex-shrink:0;width:17rem;background:#fff;border-radius:1.25rem;
  border:1px solid var(--border);box-shadow:0 20px 56px rgba(0,0,0,.09);
  padding:1.375rem;animation:infoIn .7s 1s var(--ease) both;
}
@keyframes infoIn { from{opacity:0;transform:translateX(2rem) scale(.96)}to{opacity:1;transform:none} }
.info-label { font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--light);margin-bottom:.875rem; }
.info-row { display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem; }
.info-row:last-child { margin-bottom:0; }
.info-icon { flex-shrink:0;width:2.25rem;height:2.25rem;border-radius:.75rem;background:#EFF4FF;display:flex;align-items:center;justify-content:center; }
.info-icon svg { width:1rem;height:1rem;color:var(--blue); }
.info-text { font-size:.8125rem;font-weight:500;color:#334155;line-height:1.45; }

/* Mobile */
@media (max-width:640px) {
  .hero { min-height:100svh;min-height:100dvh;padding:6rem 1.75rem 3rem;justify-content:center; }
  .hero-inner { flex-direction:column;align-items:center;text-align:center;gap:0; }
  .info-card { display:none; }
  .trust-badge { margin-bottom:1.5rem; }
  .hero-sub { display:block;font-size:1rem;margin:0 0 2rem;max-width:32rem;color:rgba(255,255,255,.75); }
  .cta-row { justify-content:center;margin-bottom:0; }
  .trust-row { display:none; }
  .btn-phone { display:none; }
  .rotating-wrap { min-width:auto;max-width:100%; }
  h1.hero-h1 { font-size:clamp(2rem,8vw,3rem) !important;margin-bottom:.875rem !important; }
}
@media (max-width:480px) { .cta-row{flex-direction:column} .btn-primary{justify-content:center} }
</style>

<section class="hero" id="hero">
  <video id="hero-video" class="hero-video" autoplay muted playsinline preload="auto" aria-hidden="true">
    <source src={client.hero.videoUrls[0]} type="video/mp4" />
  </video>
  <div class="hero-video-overlay"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="grid-bg"></div>

  <div class="hero-inner">
    <div style="flex:1;min-width:0">
      <div class="trust-badge">
        <div class="live-wrap"><div class="live-ring"></div><div class="live-core"></div></div>
        {client.hero.trustBadge}
      </div>

      <h1 class="hero-h1">
        {client.hero.headline}<br />
        <span class="rotating-wrap">
          <span class="rotating-word" id="rotating-word">{client.hero.rotatingWords[0]}</span>
        </span>
      </h1>

      <p class="hero-sub">{client.hero.subtext}</p>

      <div class="cta-row">
        <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1.04h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 15.92z"/></svg>
          {client.hero.ctaLabel}
          <span class="btn-phone">{client.brand.phone}</span>
        </a>
      </div>

      <div class="trust-row">
        <div class="trust-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> 24/7 Spoedservice</div>
        <div class="trust-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> Snelle Interventie</div>
        <div class="trust-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg> Erkende Loodgieters</div>
        <div class="trust-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/></svg> Transparante Prijzen</div>
      </div>
    </div>

    <div class="info-card">
      <div class="info-label">{client.infoCard.title}</div>
      {client.infoCard.items.map(item => (
        <div class="info-row">
          <div class="info-icon">
            {item.icon === 'clock'  && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
            {item.icon === 'shield' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
            {item.icon === 'bolt'   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
          </div>
          <span class="info-text">{item.text}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ videoUrls: client.hero.videoUrls, rotatingWords: client.hero.rotatingWords }}>
(function () {
  const v = document.getElementById('hero-video');
  if (!v) return;
  let idx = 0, switching = false;
  const pool = videoUrls.map(src => {
    const el = document.createElement('video');
    el.src = src; el.preload = 'auto'; el.muted = true; el.load();
    return el;
  });
  v.src = videoUrls[0]; v.load(); v.play().catch(() => {});
  v.addEventListener('timeupdate', () => {
    if (v.duration && (v.duration - v.currentTime) < 1.2 && !switching) {
      switching = true;
      idx = (idx + 1) % videoUrls.length;
      v.src = videoUrls[idx]; v.load(); v.play().catch(() => {});
      setTimeout(() => { switching = false; }, 800);
    }
  });
  v.addEventListener('error', () => {
    if (switching) return;
    idx = (idx + 1) % videoUrls.length;
    v.src = videoUrls[idx]; v.load(); v.play().catch(() => {});
  });
})();

(function () {
  const el = document.getElementById('rotating-word');
  if (!el || rotatingWords.length <= 1) return;
  let i = 0;
  const ease = 'cubic-bezier(0.16,1,0.3,1)';
  setInterval(() => {
    el.style.animation = 'wordOut .28s cubic-bezier(.4,0,1,1) forwards';
    setTimeout(() => {
      i = (i + 1) % rotatingWords.length;
      el.textContent = rotatingWords[i];
      el.style.animation = `wordIn .42s ${ease} forwards`;
    }, 280);
  }, 2000);
})();
</script>
