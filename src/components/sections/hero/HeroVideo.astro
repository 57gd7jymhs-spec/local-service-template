---
import { client } from '../../../config/client';
---

<style>
  .hero {
    position: relative; min-height: 100svh; min-height: 100dvh;
    display: flex; align-items: center;
    overflow: hidden; color: #fff;
    padding: 7rem 2rem 4rem;
  }
  .hero-video {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; z-index: 0; pointer-events: none;
  }
  .hero-video-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(135deg, rgba(13,30,92,.82) 0%, rgba(24,71,237,.45) 100%);
  }
  .orb {
    position: absolute; border-radius: 50%; filter: blur(80px); z-index: 1; pointer-events: none;
  }
  .orb-1 { width: 500px; height: 500px; background: rgba(24,71,237,.25); top: -100px; right: -100px; }
  .orb-2 { width: 300px; height: 300px; background: rgba(99,102,241,.2); bottom: 100px; left: 10%; }
  .hero-inner {
    position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; width: 100%;
    display: flex; align-items: center; justify-content: space-between; gap: 3rem;
  }
  .hero-content { flex: 1; max-width: 640px; }
  .trust-badge {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2);
    border-radius: 2rem; padding: .375rem .875rem;
    font-size: .8rem; font-weight: 600; letter-spacing: .03em;
    margin-bottom: 1.5rem;
  }
  .badge-dot { width: 7px; height: 7px; background: #22c55e; border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }
  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900;
    line-height: 1.05; letter-spacing: -.03em; margin: 0 0 .5rem;
  }
  .rotating-wrap { display: inline-block; overflow: hidden; vertical-align: bottom; }
  .rotating-word {
    display: block; color: var(--blue);
    animation: rotateWord 10s infinite;
  }
  @keyframes rotateWord {
    0%,18%  { transform: translateY(0); }
    20%     { transform: translateY(-100%); }
    38%,58% { transform: translateY(-100%); }
    60%     { transform: translateY(-200%); }
    /* extend as needed — JS handles this dynamically */
  }
  .hero-sub {
    font-size: 1.05rem; color: rgba(255,255,255,.75); line-height: 1.65;
    margin: 1rem 0 2rem; max-width: 520px;
  }
  .cta-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .btn-cta {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--blue); color: #fff;
    padding: .9rem 1.75rem; border-radius: .75rem;
    font-size: 1rem; font-weight: 700; text-decoration: none;
    box-shadow: 0 8px 24px rgba(24,71,237,.4);
    transition: background .2s, transform .15s, box-shadow .2s;
  }
  .btn-cta:hover { background: #0f35c4; transform: translateY(-2px); box-shadow: 0 12px 32px rgba(24,71,237,.55); }
  .trust-row {
    display: flex; gap: 2rem; margin-top: 2.5rem; flex-wrap: wrap;
  }
  .trust-item { display: flex; align-items: center; gap: .5rem; font-size: .8rem; color: rgba(255,255,255,.65); font-weight: 500; }
  .info-card {
    background: rgba(255,255,255,.95); color: var(--ink);
    border-radius: 1.25rem; padding: 1.5rem 1.75rem;
    box-shadow: 0 24px 64px rgba(0,0,0,.25);
    min-width: 260px;
  }
  .info-card-title { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: 1rem; }
  .info-item { display: flex; align-items: center; gap: .75rem; padding: .6rem 0; border-bottom: 1px solid var(--border); font-size: .875rem; font-weight: 500; }
  .info-item:last-child { border-bottom: none; }

  @media (max-width: 640px) {
    .hero { min-height: 100svh; padding: 6rem 1.75rem 3rem; justify-content: center; }
    .hero-inner { flex-direction: column; align-items: center; text-align: center; gap: 0; }
    .info-card { display: none; }
    .trust-row { display: none; }
    .hero-sub { font-size: 1rem; margin: .875rem 0 2rem; }
    .cta-row { justify-content: center; }
    h1 { font-size: clamp(2rem, 8vw, 3rem); }
  }
</style>

<section class="hero" id="hero">
  <video id="hero-video" class="hero-video" autoplay muted playsinline preload="auto" aria-hidden="true">
    <source src={client.hero.videoUrls[0]} type="video/mp4" />
  </video>
  <div class="hero-video-overlay"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <div class="hero-inner">
    <div class="hero-content">
      <div class="trust-badge">
        <span class="badge-dot"></span>
        {client.hero.trustBadge}
      </div>

      <h1>
        {client.hero.headline}<br />
        <span class="rotating-wrap">
          <span class="rotating-word" id="rotating-word">{client.hero.rotatingWords[0]}</span>
        </span>
      </h1>

      <p class="hero-sub">{client.hero.subtext}</p>

      <div class="cta-row">
        <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="btn-cta">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          {client.hero.ctaLabel} &nbsp;{client.brand.phone}
        </a>
      </div>

      <div class="trust-row">
        {client.trustItems.map(item => (
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {item.label}
          </div>
        ))}
      </div>
    </div>

    <div class="info-card">
      <div class="info-card-title">{client.infoCard.title}</div>
      {client.infoCard.items.map(item => (
        <div class="info-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {item.text}
        </div>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ videoUrls: client.hero.videoUrls, rotatingWords: client.hero.rotatingWords }}>
  // Video montage — hard cuts, preloaded pool
  (function () {
    const v = document.getElementById('hero-video');
    if (!v) return;
    let idx = 0, switching = false;
    const pool = videoUrls.map(src => {
      const el = document.createElement('video');
      el.src = src; el.preload = 'auto'; el.muted = true; el.load();
      return el;
    });
    v.src = videoUrls[0]; v.load(); v.play().catch(() => {});
    v.addEventListener('timeupdate', () => {
      if (v.duration && (v.duration - v.currentTime) < 1.2 && !switching) {
        switching = true;
        idx = (idx + 1) % videoUrls.length;
        v.src = videoUrls[idx]; v.load(); v.play().catch(() => {});
        setTimeout(() => { switching = false; }, 800);
      }
    });
    v.addEventListener('error', () => {
      if (switching) return;
      idx = (idx + 1) % videoUrls.length;
      v.src = videoUrls[idx]; v.load(); v.play().catch(() => {});
    });
  })();

  // Rotating headline word
  (function () {
    const el = document.getElementById('rotating-word');
    if (!el || rotatingWords.length <= 1) return;
    let i = 0;
    setInterval(() => {
      el.style.transition = 'opacity .25s, transform .25s';
      el.style.opacity = '0';
      el.style.transform = 'translateY(-8px)';
      setTimeout(() => {
        i = (i + 1) % rotatingWords.length;
        el.textContent = rotatingWords[i];
        el.style.transform = 'translateY(8px)';
        requestAnimationFrame(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        });
      }, 260);
    }, 2000);
  })();
</script>
