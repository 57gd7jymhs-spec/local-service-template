---
import { client } from '../../config/client';

const p = client.process;

const iconPaths: Record<string, string> = {
  phone:    '<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>',
  clock:    '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  document: '<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>',
  shield:   '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  check:    '<polyline points="20 6 9 17 4 12"/>',
  wrench:   '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>',
  star:     '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
};
---

<style>
.process-section { padding: 5rem 1.5rem; background: var(--surface); }
.process-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  position: relative;
  margin-top: 3.5rem;
}
/* Connector line between steps */
.process-steps::before {
  content: '';
  position: absolute;
  top: 2.25rem;
  left: calc(12.5% + 1.5rem);
  right: calc(12.5% + 1.5rem);
  height: 2px;
  background: linear-gradient(to right, var(--blue), rgba(24,71,237,.2));
  z-index: 0;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 0 1rem;
  position: relative;
  z-index: 1;
}
.step-icon-wrap {
  width: 4.5rem; height: 4.5rem;
  background: var(--surface);
  border: 2px solid var(--blue);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.25rem;
  position: relative;
  box-shadow: 0 0 0 6px var(--bg), 0 4px 20px rgba(24,71,237,.15);
  transition: transform .25s var(--ease), box-shadow .25s var(--ease);
}
.step:hover .step-icon-wrap {
  transform: translateY(-3px);
  box-shadow: 0 0 0 6px var(--bg), 0 12px 32px rgba(24,71,237,.2);
}
.step-icon-wrap svg { width: 1.375rem; height: 1.375rem; color: var(--blue); }
.step-number {
  position: absolute;
  top: -.5rem; right: -.5rem;
  width: 1.375rem; height: 1.375rem;
  background: var(--blue); color: #fff;
  border-radius: 50%;
  font-size: .625rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  border: 2px solid var(--bg);
}
.step h3 {
  font-size: 1rem; font-weight: 800;
  color: var(--navy);
  letter-spacing: -.02em;
  margin: 0 0 .625rem;
  line-height: 1.25;
}
.step p {
  font-size: .875rem; color: var(--muted);
  line-height: 1.65; margin: 0;
}
@media (max-width: 900px) {
  .process-steps { grid-template-columns: repeat(2, 1fr); gap: 2.5rem; }
  .process-steps::before { display: none; }
}
@media (max-width: 540px) {
  .process-steps { grid-template-columns: 1fr; gap: 2rem; }
  .step { flex-direction: row; text-align: left; gap: 1.25rem; align-items: flex-start; }
  .step-icon-wrap { flex-shrink: 0; margin-bottom: 0; width: 3.5rem; height: 3.5rem; }
}
</style>

<section class="process-section" id="werkwijze">
  <div class="wrap">
    <div class="section-header" data-reveal>
      <span class="eyebrow">{p.eyebrow}</span>
      <h2>{p.heading}</h2>
      {p.subtext && <p>{p.subtext}</p>}
    </div>

    <div class="process-steps">
      {p.steps.map((step, i) => (
        <div class="step" data-reveal data-delay={String(i + 1)}>
          <div class="step-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[step.icon] ?? iconPaths.check} />
            <span class="step-number">{step.number}</span>
          </div>
          <div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
