---
import { client } from '../../../config/client';

const s = client.sections.cta;
const phone = client.brand.phone.replace(/\s/g, '');
---

<style>
.split-section { padding:5rem 1.5rem; background:var(--surface); }
.split-inner {
  display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;
  max-width:1100px;margin:0 auto;
}
.split-image {
  border-radius:1.5rem;overflow:hidden;position:relative;
  aspect-ratio:4/5;background:var(--navy);
}
.split-image img { width:100%;height:100%;object-fit:cover;display:block; }
.split-image-overlay {
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(13,30,92,.6) 0%,transparent 60%);
}
.split-badge {
  position:absolute;bottom:1.5rem;left:1.5rem;
  background:rgba(255,255,255,.95);border-radius:.875rem;padding:.875rem 1.25rem;
  display:flex;align-items:center;gap:.75rem;
  backdrop-filter:blur(8px);box-shadow:0 8px 24px rgba(0,0,0,.12);
}
.split-badge-dot { width:.625rem;height:.625rem;border-radius:50%;background:#22c55e;flex-shrink:0; }
.split-badge-text { font-size:.8125rem;font-weight:700;color:var(--navy); }

.split-content { display:flex;flex-direction:column;gap:2rem; }
.split-eyebrow { font-size:.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--blue); }
.split-heading { font-size:clamp(1.75rem,3.5vw,2.75rem);font-weight:900;color:var(--navy);letter-spacing:-.03em;line-height:1.1;margin:0; }
.split-subtext { font-size:1rem;color:var(--muted);line-height:1.7;margin:0; }
.split-cta { display:flex;flex-direction:column;gap:1rem; }
.btn-split-call {
  display:inline-flex;align-items:center;justify-content:center;gap:.75rem;
  background:var(--blue);color:#fff;font-weight:700;font-size:1.0625rem;
  padding:1rem 2rem;border-radius:.875rem;text-decoration:none;
  box-shadow:0 8px 28px rgba(24,71,237,.28);transition:background .2s,transform .2s;
}
.btn-split-call:hover { background:#1238C7;transform:translateY(-2px); }
.btn-split-call svg { width:1.125rem;height:1.125rem; }
.split-assurances {
  display:flex;flex-wrap:wrap;gap:.75rem 1.5rem;
}
.assurance { display:flex;align-items:center;gap:.4rem;font-size:.85rem;color:var(--muted);font-weight:500; }
.assurance svg { color:#22c55e;width:.9rem;height:.9rem;flex-shrink:0; }

@media(max-width:768px){
  .split-inner { grid-template-columns:1fr;gap:2.5rem; }
  .split-image { aspect-ratio:16/9; }
}
</style>

<section class="split-section section" id="contact">
  <div class="wrap">
    <div class="split-inner">
      <div class="split-image" data-reveal>
        <img src={s.image} alt={client.brand.name} loading="lazy" />
        <div class="split-image-overlay"></div>
        <div class="split-badge">
          <span class="split-badge-dot"></span>
          <span class="split-badge-text">Nu beschikbaar</span>
        </div>
      </div>

      <div class="split-content" data-reveal data-delay="2">
        <span class="split-eyebrow">{client.sections.services.eyebrow}</span>
        <h2 class="split-heading">{s.heading}</h2>
        <p class="split-subtext">{s.subtext}</p>
        <div class="split-cta">
          <a href={`tel:${phone}`} class="btn-split-call">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1.04h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 15.92z"/></svg>
            {s.ctaLabel}
          </a>
          <div class="split-assurances">
            {s.assurances.map(a => (
              <div class="assurance">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {a}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
