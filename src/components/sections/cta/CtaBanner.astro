---
import { client } from '../../../config/client';
---

<style>
  .cta-section {
    background: var(--navy); color: #fff;
    padding: 5rem 2rem; text-align: center;
  }
  .cta-inner { max-width: 640px; margin: 0 auto; }
  h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem); font-weight: 900;
    letter-spacing: -.03em; line-height: 1.1; margin: 0 0 1rem;
  }
  p { color: rgba(255,255,255,.7); font-size: 1rem; line-height: 1.6; margin: 0 0 2rem; }
  .btn {
    display: inline-flex; align-items: center; gap: .625rem;
    background: var(--blue); color: #fff;
    padding: 1rem 2rem; border-radius: .75rem;
    font-size: 1.05rem; font-weight: 700; text-decoration: none;
    box-shadow: 0 8px 24px rgba(24,71,237,.4);
    transition: background .2s, transform .15s;
  }
  .btn:hover { background: #0f35c4; transform: translateY(-2px); }
  .availability {
    margin-top: 1.25rem; font-size: .8rem; color: rgba(255,255,255,.4);
  }
</style>

<section class="cta-section">
  <div class="cta-inner">
    <h2>Probleem? Wij staan klaar.</h2>
    <p>Gemiddeld binnen 45 minuten ter plaatse — 7 dagen per week, 24 uur per dag. Geen verborgen kosten.</p>
    <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
      </svg>
      Bel {client.brand.phone}
    </a>
    <div class="availability">24/7 bereikbaar — ook in het weekend en op feestdagen</div>
  </div>
</section>
