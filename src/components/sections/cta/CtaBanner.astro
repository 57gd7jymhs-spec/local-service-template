---
import { client } from '../../../config/client';

const s = client.sections.cta;
const phone = client.brand.phone.replace(/\s/g, '');
---

<style>
.cta-section { background:var(--navy);padding:5rem 1.5rem;position:relative;overflow:hidden; }
.cta-section::before { content:'';position:absolute;top:-12rem;right:-12rem;width:36rem;height:36rem;border-radius:50%;background:rgba(24,71,237,.25);filter:blur(72px);pointer-events:none; }
.cta-section::after { content:'';position:absolute;bottom:-8rem;left:-8rem;width:24rem;height:24rem;border-radius:50%;background:rgba(56,189,248,.12);filter:blur(56px);pointer-events:none; }
.cta-inner { position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;text-align:center;gap:2.5rem; }
.cta-inner > [data-reveal] { display:flex;flex-direction:column;align-items:center;width:100%; }
.cta-inner h2 { font-size:clamp(2rem,4vw,3rem) !important;font-weight:900 !important;color:#fff !important;letter-spacing:-.03em !important;line-height:1.1 !important;margin:0 0 1rem !important; }
.cta-sub { font-size:1.125rem;color:rgba(255,255,255,.7);line-height:1.65;max-width:38rem;margin:0 0 2rem; }
.cta-actions { display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1.5rem;justify-content:center; }
.btn-cta-call { display:inline-flex;align-items:center;gap:.625rem;background:#fff;color:var(--blue);font-weight:700;font-size:1rem;padding:.875rem 1.75rem;border-radius:.875rem;text-decoration:none;box-shadow:0 8px 24px rgba(0,0,0,.2);transition:transform .2s,box-shadow .2s; }
.btn-cta-call:hover { transform:translateY(-2px);box-shadow:0 12px 32px rgba(0,0,0,.28); }
.btn-cta-call svg { width:1.125rem;height:1.125rem; }
.btn-cta-copy { display:inline-flex;align-items:center;gap:.625rem;background:rgba(255,255,255,.1);color:#fff;font-weight:600;font-size:1rem;padding:.875rem 1.75rem;border-radius:.875rem;border:1px solid rgba(255,255,255,.2);cursor:pointer;transition:background .2s,transform .2s;font-family:inherit; }
.btn-cta-copy:hover { background:rgba(255,255,255,.18);transform:translateY(-1px); }
.btn-cta-copy svg { width:1.125rem;height:1.125rem; }
.btn-cta-copy.copied { background:rgba(74,222,128,.2);border-color:rgba(74,222,128,.4);color:#4ade80; }
.cta-assurances { display:flex;flex-wrap:wrap;gap:1rem 2rem;margin-top:1.5rem;justify-content:center; }
.assurance { display:flex;align-items:center;gap:.5rem;font-size:.875rem;font-weight:500;color:rgba(255,255,255,.7); }
.assurance svg { color:#4ADE80;width:1rem;height:1rem;flex-shrink:0; }
.cta-cards { display:flex;flex-direction:row;gap:1rem;flex-wrap:wrap;justify-content:center; }
.cta-card { background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:1.25rem;padding:1.5rem 1.75rem;backdrop-filter:blur(8px);flex:1;min-width:11rem;max-width:16rem;text-align:center; }
.cta-card-title { font-size:.75rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:.625rem; }
.cta-card-value { font-size:1.875rem;font-weight:900;color:#fff;letter-spacing:-.03em;line-height:1;margin-bottom:.375rem; }
.cta-card-sub { font-size:.8125rem;color:rgba(255,255,255,.6);line-height:1.5; }
@media(max-width:560px){ .cta-cards{display:none} }
</style>

<section class="cta-section" id="contact">
  <div class="wrap">
    <div class="cta-inner">
      <div data-reveal>
        <h2>{s.heading}</h2>
        <p class="cta-sub">{s.subtext}</p>
        <div class="cta-actions">
          <a href={`tel:${phone}`} class="btn-cta-call">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1.04h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 15.92z"/></svg>
            {s.ctaLabel}
          </a>
          <button class="btn-cta-copy" id="copyNumBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span>Kopieer nummer</span>
          </button>
        </div>
        <div class="cta-assurances">
          {s.assurances.map(a => (
            <div class="assurance">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              {a}
            </div>
          ))}
        </div>
      </div>
      <div class="cta-cards">
        {client.trustItems.slice(0, 2).map(item => (
          <div class="cta-card">
            <div class="cta-card-title">{item.label}</div>
            <div class="cta-card-value">{item.value}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script define:vars={{ phone }}>
const btn = document.getElementById('copyNumBtn');
if (btn) {
  btn.addEventListener('click', () => {
    navigator.clipboard.writeText(phone).then(() => {
      btn.classList.add('copied');
      btn.querySelector('span').textContent = 'Gekopieerd!';
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.querySelector('span').textContent = 'Kopieer nummer';
      }, 2200);
    });
  });
}
</script>
