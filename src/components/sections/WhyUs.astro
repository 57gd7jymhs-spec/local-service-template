---
import { client } from '../../config/client';

const w = client.sections.whyUs;

const badgeIconPaths: Record<string, string> = {
  clock:    '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  document: '<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>',
  shield:   '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  location: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
  bolt:     '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  star:     '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
};
---

<style>
.why-section { padding:5rem 1.5rem; background:var(--surface); }
.why-grid { display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;position:relative; }
.why-grid::after {
  content:'';position:absolute;left:50%;top:2rem;width:2px;
  height:var(--line-h,0px);
  background:linear-gradient(to bottom,var(--blue),rgba(24,71,237,.15));
  border-radius:2px;transform:translateX(-50%);pointer-events:none;z-index:0;
}
.why-card { background:#fff;border-radius:1.25rem;border:1px solid var(--border);padding:2rem;transition:box-shadow .3s var(--ease); }
.why-card:hover { box-shadow:0 10px 32px rgba(24,71,237,.09); }
.why-number { display:inline-flex;align-items:center;justify-content:center;width:2rem;height:2rem;border-radius:50%;background:var(--blue);color:#fff;font-size:.8125rem;font-weight:900;line-height:1;margin-bottom:1.25rem;flex-shrink:0; }
.why-card h3 { font-size:1.1875rem;font-weight:800;color:var(--navy);margin:0 0 .75rem;letter-spacing:-.02em; }
.why-card p { font-size:.9375rem;color:var(--muted);line-height:1.65;margin:0 0 1.25rem; }
.why-badge { display:inline-flex;align-items:center;gap:.5rem;font-size:.75rem;font-weight:600;color:var(--blue);background:#EFF4FF;border-radius:.5rem;padding:.375rem .75rem; }
.why-badge svg { width:.875rem;height:.875rem; }
@media(max-width:768px){
  .why-grid { grid-template-columns:1fr;padding-left:2.75rem; }
  .why-grid::after { left:.875rem;top:1.5rem;width:2px;transform:none; }
  .why-card { position:relative; }
  .why-number { position:absolute;left:-2.75rem;top:1.5rem;width:1.75rem;height:1.75rem;font-size:.75rem;margin-bottom:0;z-index:1; }
}
</style>

<section class="why-section" id="waarom">
  <div class="wrap">
    <div class="section-header" data-reveal>
      <span class="eyebrow">{w.eyebrow}</span>
      <h2>{w.heading}</h2>
      <p>{w.subtext}</p>
    </div>
    <div class="why-grid" id="whyGrid">
      {w.points.map((pt, i) => (
        <div class="why-card" data-reveal data-delay={String(i + 1)}>
          <div class="why-number">{pt.number}</div>
          <h3>{pt.title}</h3>
          <p>{pt.body}</p>
          <div class="why-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 set:html={badgeIconPaths[pt.badgeIcon] ?? badgeIconPaths.bolt} />
            {pt.badge}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
const whyGrid = document.getElementById('whyGrid');
if (whyGrid) {
  function updateLine() {
    const rect = whyGrid.getBoundingClientRect();
    const vh = window.innerHeight;
    const progress = Math.max(0, Math.min(1, (vh - rect.top) / (rect.height + vh * 0.6)));
    whyGrid.style.setProperty('--line-h', Math.round(progress * Math.max(0, rect.height - 48)) + 'px');
  }
  window.addEventListener('scroll', updateLine, { passive: true });
  updateLine();
}
</script>
