---
import { client } from '../../config/client';

const iconPaths: Record<string, string> = {
  clock:  '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  users:  '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>',
  badge:  '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  bolt:   '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  euro:   '<path d="M4 10h12M4 14h12M19.5 9.5A7.5 7.5 0 104 14"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  star:   '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  check:  '<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>',
};

// Extract the animatable integer and suffix from a trust-strip value string.
// Dutch thousands: "4.800+" → {num:4800, suffix:"+"}  |  "45 min" → {num:45, suffix:" min"}
// Decimals like "4.9" and plain text like "Gratis" → null (no animation, shown as-is)
function extractNum(val: string): { num: number; suffix: string } | null {
  // Dutch thousands-formatted: digit(s) + one or more groups of .NNN
  const thousands = val.match(/^(\d+(?:\.\d{3})+)(.*)$/);
  if (thousands) {
    const n = parseInt(thousands[1].replace(/\./g, ''), 10);
    return isNaN(n) ? null : { num: n, suffix: thousands[2] };
  }
  // Plain integer (no dots): "45 min", "8 jr", "7 dagen"
  const plain = val.match(/^(\d+)(.*)$/);
  if (plain) {
    const n = parseInt(plain[1], 10);
    return isNaN(n) ? null : { num: n, suffix: plain[2] };
  }
  // Decimals ("4.9"), text ("Gratis"), ranges ("< 45 min") → show as-is
  return null;
}
---

<style>
.trust-section { padding:4.5rem 1.5rem; background:var(--surface); }
.trust-grid { display:grid;grid-template-columns:repeat(4,1fr);gap:2rem; }
.trust-card {
  text-align:center;padding:2rem 1.5rem;background:#fff;border-radius:1.25rem;
  border:1px solid var(--border);box-shadow:0 2px 12px rgba(0,0,0,.04);
  transition:transform .25s var(--ease),box-shadow .25s var(--ease);
}
.trust-card:hover { transform:translateY(-3px);box-shadow:0 8px 28px rgba(24,71,237,.1); }
.trust-card svg { display:block;margin:0 auto 1rem;color:var(--blue);width:1.75rem;height:1.75rem; }
.trust-number { font-size:2.5rem;font-weight:900;color:var(--navy);letter-spacing:-.03em;line-height:1;white-space:nowrap; }
.trust-label { font-size:.875rem;color:var(--muted);margin-top:.375rem; }
@media(max-width:768px){ .trust-grid{grid-template-columns:repeat(2,1fr)} }
@media(max-width:480px){ .trust-grid{grid-template-columns:repeat(2,1fr);gap:1rem} .trust-card{padding:1.5rem 1rem} .trust-number{font-size:1.5rem} }
</style>

<section class="trust-section" id="vertrouwen">
  <div class="wrap">
    <div class="trust-grid">
      {client.trustItems.map((item, i) => {
        const parsed = extractNum(item.value);
        return (
          <div class="trust-card" data-reveal data-delay={String(i + 1)}
               data-count={parsed ? String(parsed.num) : undefined}
               data-suffix={parsed ? parsed.suffix : undefined}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                 set:html={iconPaths[item.icon] ?? iconPaths.bolt} />
            <div class="trust-number">{item.value}</div>
            <div class="trust-label">{item.label}</div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
const counterObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target as HTMLElement;
    const numEl = el.querySelector('.trust-number') as HTMLElement | null;
    const target = parseInt(el.dataset.count ?? '', 10);
    const suffix = el.dataset.suffix ?? '';
    if (!target || !numEl) return;
    const dur = 1400, start = performance.now();
    (function tick(now: number) {
      const p = Math.min((now - start) / dur, 1), eased = 1 - Math.pow(1 - p, 3);
      numEl.textContent = Math.round(eased * target).toLocaleString('nl-BE') + suffix;
      if (p < 1) requestAnimationFrame(tick);
    })(start);
    counterObs.unobserve(el);
  });
}, { threshold: 0.25 });
document.querySelectorAll('[data-count]').forEach(el => counterObs.observe(el));
</script>
