---
import { client } from '../../config/client';

interface Props {
  brandName: string;
  phone: string;
  logo: string;
}
const { brandName, phone, logo } = Astro.props;
---

<style>
#progress-bar {
  position:fixed;top:0;left:0;height:3px;width:0%;
  background:var(--blue);z-index:9999;will-change:width;transition:width .05s linear;
}
#nav {
  position:fixed;top:1rem;left:50%;transform:translateX(-50%) translateY(-20px);
  z-index:900;width:calc(100% - 2rem);max-width:72rem;
  display:flex;align-items:center;justify-content:space-between;
  padding:.75rem 1.25rem;
  border-radius:1rem;border:1px solid rgba(255,255,255,.6);
  background:rgba(255,255,255,.72);backdrop-filter:blur(14px);
  box-shadow:0 4px 20px rgba(0,0,0,.06);
  opacity:0;
  transition:background .35s var(--ease),border-color .35s,box-shadow .35s,color .35s;
  animation:navIn .5s .08s var(--ease) forwards;
}
@keyframes navIn { to{opacity:1;transform:translateX(-50%) translateY(0)} }
#nav.scrolled {
  background:var(--blue);
  border-color:rgba(255,255,255,.15);
  box-shadow:0 8px 32px rgba(24,71,237,.35);
}
#nav.scrolled .nav-logo { color:#fff; }
#nav.scrolled .nav-logo-icon { background:rgba(255,255,255,.9); }
#nav.scrolled .nav-links a { color:rgba(255,255,255,.8); }
#nav.scrolled .nav-links a:hover { color:#fff; }
#nav.scrolled .nav-cta { background:#fff;color:var(--blue); }
#nav.scrolled .nav-cta:hover { background:rgba(255,255,255,.9);transform:translateY(-1px); }
.nav-logo { display:flex;align-items:center;gap:.5rem;font-weight:800;color:var(--navy);font-size:1.125rem;text-decoration:none;transition:color .35s; }
.nav-logo-icon { width:2.25rem;height:2.25rem;background:#fff;border-radius:.625rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;padding:4px;transition:box-shadow .35s; }
.nav-logo-icon img { width:100%;height:100%;object-fit:contain;display:block; }
#nav.scrolled .nav-logo-icon { box-shadow:0 0 0 1px rgba(255,255,255,.25); }
.nav-links { display:flex;gap:1.5rem;list-style:none;margin:0;padding:0; }
.nav-links a { color:var(--muted);text-decoration:none;font-size:.875rem;font-weight:500;transition:color .2s; }
.nav-links a:hover { color:var(--blue); }
.nav-cta { display:flex;align-items:center;gap:.5rem;background:var(--navy);color:#fff;padding:.5rem 1.125rem;border-radius:.75rem;font-size:.875rem;font-weight:600;text-decoration:none;transition:background .2s,transform .2s,color .2s; }
.nav-cta:hover { background:var(--blue);transform:translateY(-1px); }
.nav-cta svg { width:1rem;height:1rem; }
.nav-phone { display:none; }
@media(min-width:640px){ .nav-phone{display:block} }
@media(max-width:768px){ .nav-links{display:none} }
</style>

<div id="progress-bar"></div>

<nav id="nav">
  <a class="nav-logo" href="/">
    <div class="nav-logo-icon">
      <img src={logo} alt={brandName} />
    </div>
    {brandName}
  </a>
  <ul class="nav-links">
    <li><a href="/#diensten">Diensten</a></li>
    <li><a href="/#reviews">Reviews</a></li>
    <li><a href="/#waarom">Over ons</a></li>
  </ul>
  <a href={`tel:${phone.replace(/\s/g,'')}`} class="nav-cta">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1.04h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 15.92z"/></svg>
    <span class="nav-phone">{phone}</span>
  </a>
</nav>

<div class="sticky-mobile">
  <a href={`tel:${phone.replace(/\s/g,'')}`}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1.04h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 15.92z"/></svg>
    Bel Nu — 24/7 Spoed
  </a>
</div>

<script>
const progressBar = document.getElementById('progress-bar');
const nav = document.getElementById('nav');
const stickyBar = document.querySelector('.sticky-mobile');
window.addEventListener('scroll', () => {
  const scrollable = document.documentElement.scrollHeight - window.innerHeight;
  if (progressBar) progressBar.style.width = (scrollable > 0 ? window.scrollY / scrollable * 100 : 0) + '%';
  if (nav) nav.classList.toggle('scrolled', window.scrollY > 60);
  if (stickyBar) stickyBar.classList.toggle('show', window.scrollY > 420);
}, { passive: true });

const revealObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); }
  });
}, { threshold: 0.12 });
document.querySelectorAll('[data-reveal]').forEach(el => revealObs.observe(el));
</script>
