---
import { client } from '../../config/client';
---

<style>
footer { background:#0A1540;padding:3.5rem 1.5rem 2rem; }
.footer-inner { display:flex;gap:3rem;justify-content:space-between;flex-wrap:wrap;margin-bottom:2.5rem; }
.footer-logo { display:flex;align-items:center;gap:.625rem;font-weight:800;color:#fff;font-size:1.125rem;margin-bottom:.625rem; }
.footer-logo-icon { width:2.25rem;height:2.25rem;background:#fff;border-radius:.625rem;display:flex;align-items:center;justify-content:center;padding:4px;flex-shrink:0; }
.footer-logo-icon img { width:100%;height:100%;object-fit:contain;display:block; }
.footer-tagline { font-size:.875rem;color:rgba(255,255,255,.45); }
.footer-cols { display:flex;gap:3rem;flex-wrap:wrap; }
.footer-col { display:flex;flex-direction:column;gap:.5rem;min-width:9rem; }
.footer-col-title { font-size:.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.25rem; }
.footer-col a,.footer-col p { font-size:.9375rem;color:rgba(255,255,255,.65);text-decoration:none;margin:0;transition:color .15s;line-height:1.6; }
.footer-col a:hover { color:#fff; }
.footer-col .phone { color:#fff;font-weight:700;font-size:1.0625rem; }
.footer-col .emergency { color:var(--blue);font-weight:700; }
.footer-bottom { border-top:1px solid rgba(255,255,255,.08);padding-top:1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem; }
.footer-legal { font-size:.8125rem;color:rgba(255,255,255,.35); }
.footer-legal-row { display:flex;gap:2rem;flex-wrap:wrap; }
</style>

<footer>
  <div class="wrap">
    <div class="footer-inner">
      <div>
        <div class="footer-logo">
          <div class="footer-logo-icon">
            <img src={client.brand.logoNegative} alt={client.brand.name}>
          </div>
          {client.brand.name}
        </div>
        <div class="footer-tagline">{client.brand.tagline} — {client.brand.location} &amp; omgeving</div>
      </div>
      <div class="footer-cols">
        <div class="footer-col">
          <span class="footer-col-title">Contact</span>
          <a href={`tel:${client.brand.phone.replace(/\s/g,'')}`} class="phone">{client.brand.phone}</a>
          <a href={`mailto:${client.brand.email}`}>{client.brand.email}</a>
          <p>{client.footer.address}</p>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Openingstijden</span>
          <p>{client.footer.hours}</p>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Diensten</span>
          {client.services.map(s => (
            <a href="/diensten">{s.title}</a>
          ))}
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-legal">{client.footer.copyright}. Alle rechten voorbehouden.</span>
      <div class="footer-legal-row">
        <span class="footer-legal">Gecertificeerd &amp; verzekerd</span>
        <span class="footer-legal">Vaste prijs garantie</span>
        <span class="footer-legal">BTW {client.footer.vatNumber}</span>
      </div>
    </div>
  </div>
</footer>
